{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blueprint State Machines",
  "type": "object",
  "required": ["version", "state_machines"],
  "properties": {
    "version": { "type": "string" },
    "state_machines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "owner", "entity", "initial_state", "states", "transitions"],
        "properties": {
          "name": { "type": "string" },
          "owner": { "type": "string" },
          "entity": { "type": "string" },
          "initial_state": { "type": "string" },
          "states": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string" }
          },
          "transitions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["from", "event", "to"],
              "properties": {
                "from": { "type": "string" },
                "event": { "type": "string" },
                "to": { "type": "string" },
                "guards": { "type": "array", "items": { "type": "string" } },
                "side_effects": { "type": "array", "items": { "type": "string" } },
                "errors": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    }
  }
}
