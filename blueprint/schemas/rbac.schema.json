{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blueprint RBAC",
  "type": "object",
  "required": ["version", "roles"],
  "properties": {
    "version": { "type": "string" },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "owner", "permissions"],
        "properties": {
          "name": { "type": "string" },
          "owner": { "type": "string" },
          "description": { "type": "string" },
          "permissions": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "actions"],
        "properties": {
          "name": { "type": "string" },
          "data_classification": { "type": "string" },
          "actions": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "resource", "action", "allowed_roles", "linked_story"],
        "properties": {
          "id": { "type": "string" },
          "resource": { "type": "string" },
          "action": { "type": "string" },
          "allowed_roles": { "type": "array", "items": { "type": "string" } },
          "audit_required": { "type": "boolean" },
          "linked_story": { "type": "string" }
        }
      }
    }
  }
}
